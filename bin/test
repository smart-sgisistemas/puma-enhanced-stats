#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
IMAGE="${PUMA_ENHANCED_STATS_IMAGE:-puma-enhanced-stats:dev}"
RUBY_VERSION="${RUBY_VERSION:-3.0}"

docker build \
  --build-arg "RUBY_VERSION=${RUBY_VERSION}" \
  -t "${IMAGE}" \
  "${ROOT}"

docker run --rm \
  ${PUMA_VERSION:+-e "PUMA_VERSION=${PUMA_VERSION}"} \
  ${RAILS_VERSION:+-e "RAILS_VERSION=${RAILS_VERSION}"} \
  "${IMAGE}" \
  bundle exec rake "$@"
