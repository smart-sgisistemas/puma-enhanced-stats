{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/smart-sgisistemas/puma-enhanced-stats/schema/enhanced-stats-v1.json",
  "title": "Puma Enhanced Stats",
  "description": "JSON contract for GET /enhanced-stats and pumactl enhanced-stats. Base shape follows Puma GET /stats with flat gem extensions. See docs/json-contract.md.",
  "oneOf": [
    { "$ref": "#/$defs/cluster_payload" },
    { "$ref": "#/$defs/single_payload" }
  ],
  "$defs": {
    "cluster_payload": {
      "type": "object",
      "description": "Cluster mode: Puma /stats cluster shape plus flat aggregates and enhanced worker rows.",
      "required": [
        "started_at",
        "workers",
        "phase",
        "booted_workers",
        "old_workers",
        "collected_at",
        "workers_total",
        "workers_reporting",
        "workers_stale",
        "requests_in_flight",
        "backlog_total",
        "busy_threads_total",
        "max_threads_total",
        "pool_capacity_total",
        "worker_status",
        "versions"
      ],
      "properties": {
        "started_at": { "type": "string", "format": "date-time" },
        "workers": { "type": "integer", "minimum": 0 },
        "phase": { "type": "integer", "minimum": 0 },
        "booted_workers": { "type": "integer", "minimum": 0 },
        "old_workers": { "type": "integer", "minimum": 0 },
        "collected_at": { "type": "string", "format": "date-time" },
        "workers_total": { "type": "integer", "minimum": 0 },
        "workers_reporting": { "type": "integer", "minimum": 0 },
        "workers_stale": { "type": "integer", "minimum": 0 },
        "requests_in_flight": { "type": "integer", "minimum": 0 },
        "backlog_total": { "type": "integer", "minimum": 0 },
        "busy_threads_total": { "type": "integer", "minimum": 0 },
        "max_threads_total": { "type": "integer", "minimum": 0 },
        "pool_capacity_total": { "type": "integer", "minimum": 0 },
        "worker_status": {
          "type": "array",
          "items": { "$ref": "#/$defs/cluster_worker" }
        },
        "versions": { "$ref": "#/$defs/versions" }
      },
      "additionalProperties": false
    },
    "single_payload": {
      "type": "object",
      "description": "Single mode: flat Puma /stats counters plus collected_at, requests, and requests_in_flight.",
      "required": [
        "collected_at",
        "backlog",
        "running",
        "pool_capacity",
        "busy_threads",
        "backlog_max",
        "max_threads",
        "requests_count",
        "reactor_max",
        "requests_in_flight",
        "requests",
        "versions"
      ],
      "properties": {
        "started_at": { "type": "string", "format": "date-time" },
        "collected_at": { "type": "string", "format": "date-time" },
        "backlog": { "type": "integer", "minimum": 0 },
        "running": { "type": "integer", "minimum": 0 },
        "pool_capacity": { "type": "integer", "minimum": 0 },
        "busy_threads": { "type": "integer", "minimum": 0 },
        "io_threads": { "type": "integer", "minimum": 0 },
        "backlog_max": { "type": "integer", "minimum": 0 },
        "max_threads": { "type": "integer", "minimum": 0 },
        "requests_count": { "type": "integer", "minimum": 0 },
        "reactor_max": { "type": "integer", "minimum": 0 },
        "requests_in_flight": { "type": "integer", "minimum": 0 },
        "requests": {
          "type": "array",
          "items": { "$ref": "#/$defs/request_item" }
        },
        "versions": { "$ref": "#/$defs/single_versions" }
      },
      "additionalProperties": false
    },
    "single_versions": {
      "type": "object",
      "required": ["puma-enhanced-stats"],
      "properties": {
        "puma": { "type": "string" },
        "puma-enhanced-stats": { "type": "string" },
        "ruby": {
          "type": "object",
          "required": ["engine", "version", "patchlevel"],
          "properties": {
            "engine": { "type": "string" },
            "version": { "type": "string" },
            "patchlevel": { "type": "integer" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "cluster_worker": {
      "type": "object",
      "required": [
        "index",
        "pid",
        "phase",
        "booted",
        "started_at",
        "last_enhanced_checkin",
        "last_enhanced_status",
        "requests"
      ],
      "properties": {
        "index": { "type": "integer", "minimum": 0 },
        "pid": { "type": "integer" },
        "phase": { "type": "integer", "minimum": 0 },
        "booted": { "type": "boolean" },
        "started_at": { "type": "string", "format": "date-time" },
        "last_enhanced_checkin": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "last_enhanced_status": { "$ref": "#/$defs/puma_stats" },
        "requests": {
          "type": "array",
          "items": { "$ref": "#/$defs/request_item" }
        }
      },
      "additionalProperties": false
    },
    "request_item": {
      "type": "object",
      "required": ["id", "started_at", "session"],
      "properties": {
        "id": { "type": "string" },
        "started_at": { "type": "string", "format": "date-time" },
        "method": { "type": "string" },
        "path_info": { "type": "string" },
        "remote_ip": { "type": "string" },
        "session": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "puma_stats": {
      "type": "object",
      "required": [
        "backlog",
        "running",
        "pool_capacity",
        "busy_threads",
        "backlog_max",
        "max_threads",
        "requests_count",
        "reactor_max"
      ],
      "properties": {
        "backlog": { "type": "integer", "minimum": 0 },
        "running": { "type": "integer", "minimum": 0 },
        "pool_capacity": { "type": "integer", "minimum": 0 },
        "busy_threads": { "type": "integer", "minimum": 0 },
        "io_threads": { "type": "integer", "minimum": 0 },
        "backlog_max": { "type": "integer", "minimum": 0 },
        "max_threads": { "type": "integer", "minimum": 0 },
        "requests_count": { "type": "integer", "minimum": 0 },
        "reactor_max": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "versions": {
      "type": "object",
      "required": ["puma", "puma-enhanced-stats", "ruby"],
      "properties": {
        "puma": { "type": "string" },
        "puma-enhanced-stats": { "type": "string" },
        "ruby": {
          "type": "object",
          "required": ["engine", "version", "patchlevel"],
          "properties": {
            "engine": { "type": "string" },
            "version": { "type": "string" },
            "patchlevel": { "type": "integer" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
