module Puma
  module Enhanced
    module Stats
      VERSION: String

      class Error < StandardError
      end

      interface _RegistrySnapshot
        def items: () -> Array[Hash[Symbol, untyped]]
        def dropped_count: () -> Integer
        def truncated: () -> bool
      end

      interface _WorkerRow
        def index: () -> Integer
        def pid: () -> Integer
        def synced_at: () -> String?
        def puma: () -> Hash[Symbol, untyped]
        def requests: () -> Hash[Symbol, untyped]
      end

      interface _EnhancedStatsPayload
        def schema_version: () -> Integer
        def meta: () -> Hash[Symbol, untyped]
        def summary: () -> Hash[Symbol, untyped]
        def workers: () -> Array[_WorkerRow]
      end

      type _EnhancedWorkerRows = Array[Hash[Symbol, untyped]]

      class Configuration
        LIMIT_POLICIES: Array[Symbol]

        attr_reader request_limit: Integer
        attr_reader limit_policy: Symbol
        attr_reader max_field_length: Integer
        attr_reader truncate_suffix: String
        attr_reader fields: { request: Hash[Symbol, Field], session: Hash[Symbol, Field] }

        def self.default: () -> Configuration

        def initialize: () -> void
        def fields_for: (Symbol namespace) -> Array[Field]
        def register_fields: (Symbol | String namespace, *Symbol | String name) ?{ (Hash[untyped, untyped] source) -> untyped } -> void
        def request_limit=: (Integer | String value) -> Integer
        def limit_policy=: (Symbol | String value) -> Symbol
        def max_field_length=: (Integer | String value) -> Integer
        def truncate_suffix=: (String? value) -> String
        def keep_longest?: () -> bool
        def reject_new?: () -> bool
      end

      class Field
        attr_reader name: String
        attr_reader block: Proc?

        def initialize: (name: Symbol | String, ?block: Proc?) -> void
        def extract: (Hash[untyped, untyped] source) -> untyped
      end

      class CurrentRequests
        include Singleton

        def self.reset!: () -> void
        def self.register: (Hash[untyped, untyped] env) -> void
        def self.unregister: (Hash[untyped, untyped] env) -> void
        def self.config=: (Configuration value) -> Configuration
        def self.config: () -> Configuration
        def self.snapshot: () -> _RegistrySnapshot

        def config=: (Configuration value) -> Configuration
        def config: () -> Configuration
        def register: (Hash[untyped, untyped] env) -> void
        def unregister: (Hash[untyped, untyped] env) -> void
        def reset!: () -> void
        def snapshot: () -> _RegistrySnapshot
      end

      class CurrentRequestsMiddleware
        def initialize: (#call app) -> void
        def call: (Hash[untyped, untyped] env) -> Array[untyped]
      end

      class Snapshot
        SCHEMA_VERSION: Integer

        def initialize: (worker_check_interval: Integer, ?server: untyped, ?workers: Array[untyped]) -> void
        def to_h: () -> _EnhancedStatsPayload
      end

      module WorkerHandle
        EMPTY_ENHANCED_STATS: Hash[Symbol, untyped]

        attr_reader last_enhanced_stats: Hash[Symbol, untyped]

        def initialize: (*untyped) -> void
        def enhanced_ping!: (Hash[Symbol, untyped]? payload) -> void
      end

      module Cluster
        attr_reader enhanced_read_io: IO?
        attr_reader enhanced_write_io: IO?

        def run: () -> untyped
        def worker: (*untyped) -> untyped
        def enhanced_stats: () -> _EnhancedStatsPayload
      end

      module Worker
        def initialize: (index: Integer, master: untyped, launcher: untyped, pipes: Hash[Symbol, untyped], ?app: untyped) -> void
        def run: () -> untyped
      end

      module Single
        def enhanced_stats: () -> _EnhancedStatsPayload
      end

      module Launcher
        def runner: () -> untyped
        def run: () -> untyped
        def enhanced_stats: () -> _EnhancedStatsPayload
      end

      module Status
        def call: (Hash[untyped, untyped] env) -> Array[untyped]
      end

      module DSL
        def enhanced_stats: () { () -> void } -> Configuration

        class Builder
          def initialize: (Configuration configuration) -> void
          def request_limit: (Integer | String value) -> Integer
          def limit_policy: (Symbol | String value) -> Symbol
          def max_field_length: (Integer | String value) -> Integer
          def truncate_suffix: (String? value) -> String
          def request: (*Symbol | String name) ?{ (Hash[untyped, untyped] env) -> untyped } -> void
          def session: (*Symbol | String name) ?{ (Hash[untyped, untyped] rack_session) -> untyped } -> void
        end
      end

      class Railtie < ::Rails::Railtie
      end
    end
  end

  def self.enhanced_stats_hash: () -> Enhanced::Stats::_EnhancedStatsPayload
  def self.enhanced_stats: () -> String
end
