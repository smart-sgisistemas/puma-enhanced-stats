module Puma
  module Enhanced
    module Stats
      VERSION: String

      class Error < StandardError
      end

      interface _WorkerRow
        def index: () -> Integer
        def pid: () -> Integer
        def phase: () -> Integer
        def booted: () -> bool
        def started_at: () -> String
        def last_enhanced_checkin: () -> String?
        def last_enhanced_status: () -> Hash[Symbol, untyped]
        def requests: () -> Array[Hash[Symbol, untyped]]
      end

      interface _ClusterPayload
        def started_at: () -> String
        def workers: () -> Integer
        def phase: () -> Integer
        def booted_workers: () -> Integer
        def old_workers: () -> Integer
        def collected_at: () -> String
        def workers_total: () -> Integer
        def workers_reporting: () -> Integer
        def workers_stale: () -> Integer
        def requests_in_flight: () -> Integer
        def backlog_total: () -> Integer
        def busy_threads_total: () -> Integer
        def max_threads_total: () -> Integer
        def pool_capacity_total: () -> Integer
        def worker_status: () -> Array[_WorkerRow]
        def versions: () -> Hash[Symbol | String, untyped]
      end

      interface _SinglePayload
        def started_at: () -> String
        def collected_at: () -> String
        def requests_in_flight: () -> Integer
        def requests: () -> Array[Hash[Symbol, untyped]]
        def versions: () -> Hash[Symbol | String, untyped]
      end

      type _EnhancedStatsPayload = _ClusterPayload | _SinglePayload

      class Configuration
        attr_reader max_field_length: Integer

        def self.default: () -> Configuration

        def initialize: () -> void
        def fields_for: (Symbol namespace) -> Array[Field]
        def register_fields: (Symbol | String namespace, *Symbol | String name) ?{ (Hash[untyped, untyped] source) -> untyped } -> void
        def max_field_length=: (Integer | String value) -> Integer
      end

      class Field
        attr_reader name: String
        attr_reader block: Proc?

        def initialize: (name: Symbol | String, ?block: Proc?) -> void
        def extract: (Hash[untyped, untyped] source) -> untyped
      end

      class Middleware
        KEY: Symbol
        STARTED_AT_KEY: String

        def initialize: (#call app) -> void
        def call: (Hash[untyped, untyped] env) -> Array[untyped]
      end

      class Snapshot
        def self.server: (server: untyped, ?index: Integer) -> Hash[Symbol, untyped]
        def self.single: (server: untyped) -> _SinglePayload
        def self.cluster: (workers: Array[untyped], phase: Integer, started_at: Time?) -> _ClusterPayload

        def initialize: (?server: untyped, ?workers: Array[untyped], ?phase: Integer?, ?started_at: Time?, ?index: Integer) -> void
        def server_row: () -> Hash[Symbol, untyped]
        def single_payload: () -> _SinglePayload
        def cluster_payload: () -> _ClusterPayload

        private
      end

      module WorkerHandle
        attr_reader last_enhanced_checkin: Time?
        attr_reader last_enhanced_status: Hash[Symbol, untyped]

        def initialize: (*untyped) -> void
        def enhanced_ping!: (Hash[Symbol, untyped] payload) -> void
      end

      module Cluster
        def run: () -> untyped
        def worker: (*untyped) -> untyped
        def enhanced_stats: () -> _ClusterPayload
      end

      module Worker
        def run: () -> untyped
      end

      module Single
        def enhanced_stats: () -> _SinglePayload

        private
        def empty_enhanced_stats: () -> _SinglePayload
      end

      module Launcher
        def enhanced_stats: () -> _EnhancedStatsPayload
      end

      module Status
        def call: (Hash[untyped, untyped] env) -> Array[untyped]
      end

      module DSL
        def enhanced_stats: () { () -> void } -> Configuration

        class Builder
          def initialize: (Configuration configuration) -> void
          def max_field_length: (Integer | String value) -> Integer
          def request: (*Symbol | String name) ?{ (Hash[untyped, untyped] env) -> untyped } -> void
          def session: (*Symbol | String name) ?{ (Hash[untyped, untyped] rack_session) -> untyped } -> void
        end
      end

      class Railtie < ::Rails::Railtie
      end
    end
  end

  def self.enhanced_stats_hash: () -> Enhanced::Stats::_EnhancedStatsPayload
  def self.enhanced_stats: () -> String
end
